{
  "name": "fetchcat-n8n-workflows",
  "version": "1.0.0",
  "private": true,
  "description": "Public, tested n8n workflow templates for FetchCat Apify Actors",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "node scripts/build-workflows.mjs",
    "validate": "node scripts/validate.mjs",
    "sanitize": "node scripts/sanitize.mjs",
    "import": "node scripts/n8n-cli.mjs import",
    "execute": "node scripts/n8n-cli.mjs execute",
    "export": "node scripts/n8n-cli.mjs export",
    "package": "node scripts/package.mjs",
    "check": "npm run build && git diff --exit-code && npm run validate",
    "security:audit": "node scripts/security-audit.mjs"
  },
  "license": "MIT"
}
