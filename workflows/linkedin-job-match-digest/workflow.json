      "parameters": {
        "jsCode": "return [{\n  json: {\n    keywords: ['automation engineer', 'workflow automation'],\n    location: 'Remote',\n    candidateProfile: 'Senior automation engineer with n8n, JavaScript, APIs, and data pipeline experience.',\n    minimumScore: 70,\n    maxItems: 10,\n    sheetName: 'Jobs'\n  }\n}];"
      },
      "id": "10000000-0000-0000-4000-8000-000000000003",
      "name": "Configuration",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1040,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const config = $input.first().json;\nif (!Array.isArray(config.keywords) || config.keywords.length === 0) throw new Error('Configure at least one job keyword.');\nif (!config.candidateProfile || config.candidateProfile.length < 20) throw new Error('Candidate profile must be at least 20 characters.');\nconst maxItems = Math.max(1, Math.min(Number(config.maxItems) || 10, 10));\nreturn [{ json: {\n  actorInput: {\n    keywords: config.keywords,\n    location: config.location,\n    maxItems,\n    includeDetails: true,\n    datePosted: 'past24h',\n    sortBy: 'recent'\n  }\n} }];"
      },
      "id": "10000000-0000-0000-4000-8000-000000000004",
      "name": "Build Actor Input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -800,
        0
      ]
