    {
      "parameters": {
        "jsCode": "const qualifiedJobs = $('Validate Job Batch').first().json.qualifiedJobs;\nconst jobs = [...qualifiedJobs].sort((a, b) => b.score - a.score).slice(0, 5);\nif (jobs.length === 0) return [];\nconst escapeHtml = (value) => String(value ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/\"/g, '&quot;');\nconst slackLines = jobs.map((job, index) => (index + 1) + '. *' + job.title + '* at ' + job.company + ' (' + job.score + '/100)\\n' + job.location + ' | Posted ' + job.postedRelative + '\\n' + job.reason + '\\n' + job.url);\nconst htmlLines = jobs.map((job, index) => '<p><strong>' + (index + 1) + '. ' + escapeHtml(job.title) + '</strong> at ' + escapeHtml(job.company) + ' (' + job.score + '/100)<br>' + escapeHtml(job.location) + ' | Posted ' + escapeHtml(job.postedRelative) + '<br>' + escapeHtml(job.reason) + '<br><a href=\"' + escapeHtml(job.url) + '\">Open job</a></p>');\nconst telegramLines = jobs.map((job, index) => '<b>' + (index + 1) + '. ' + escapeHtml(job.title) + '</b> at ' + escapeHtml(job.company) + ' (' + job.score + '/100)\\n' + escapeHtml(job.location) + ' | Posted ' + escapeHtml(job.postedRelative) + '\\n' + escapeHtml(job.reason) + '\\n<a href=\"' + escapeHtml(job.url) + '\">Open job</a>');\nreturn [{ json: {\n  qualifiedJobs,\n  deliveryDestination: $('Build Actor Input').first().json.config.deliveryDestination,\n  slackMessage: '*LinkedIn Job Match Digest*\\n\\n' + slackLines.join('\\n\\n'),\n  gmailHtml: '<h2>LinkedIn Job Match Digest</h2>' + htmlLines.join(''),\n  telegramMessage: '<b>LinkedIn Job Match Digest</b>\\n\\n' + telegramLines.join('\\n\\n')\n} }];"
      },
