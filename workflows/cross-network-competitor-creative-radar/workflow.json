    {
      "parameters": {
        "jsCode": "const data = $('Normalize Rows and Compare Snapshot').first().json;\nconst ai = $json;\nif (!data.normalized?.length) return [{json:{skipDelivery:true,reason:'No observed source rows; no AI, Drive, Slack, snapshot, or delivery writes allowed.'}}];\nconst lines=['# Cross-network competitor creative radar','',`Watchlist: ${data.watchlistLabel} (${data.market})`,'Collection scope: '+JSON.stringify(data.counts),'','## Guardrails','- Meta, Google, and TikTok are reported separately; no blended rank or score is calculated.','- Absence means not observed unless a source explicitly proves retirement.','','## Evidence rows',...data.normalized.map(r=>`- **${r.source}** ${r.source_ad_id} — ${r.message_primary || 'no copy'} — ${r.evidence_url || 'no evidence URL'} (run ${r.apify_run_id || 'n/a'}, dataset ${r.apify_dataset_id || 'n/a'})`),'','## AI themes (source-separated)',JSON.stringify(ai).slice(0,4000),'','## Source warnings',...(data.warnings?.length ? data.warnings.map(w=>`- ${w}`) : ['- none'])];\nreturn [{json:{...data, ai, markdown:lines.join('\\n'),fileName:`creative-radar-${data.runKey}.md`.replace(/[^a-z0-9_.-]/gi,'-'),idempotencyKey:data.idempotencyKey,slackNotify:Boolean(data.slackNotify)}}];"
      },
      "id": "23100000-0000-4000-8000-000000000013",
      "name": "Render Evidence-linked Markdown Brief",
      "type": "n8n-nodes-base.code",
