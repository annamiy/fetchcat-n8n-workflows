      "id": "23100000-0000-4000-8000-000000000012",
      "name": "Classify Themes with OpenAI gpt-5.4-mini",
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 1.8,
      "position": [
        -60,
        20
