      "id": "23100000-0000-4000-8000-000000000010",
      "name": "Run TikTok Actor (fetch_cat/tiktok-ads-library-scraper)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -600,
        220
      ]
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst normalized = [];\nconst sourceStatus = {};\nfunction detectSource(j, paired) {\n  const name = paired?.json?.actorId || paired?.json?.actId || paired?.json?.actorTaskId || '';\n  if (/facebook|meta/i.test(name)) return 'meta';\n  if (/google/i.test(name)) return 'google';\n  if (/tiktok/i.test(name)) return 'tiktok';\n  return j.source || j.platform || 'unknown';\n}\nfor (const item of items) {\n  const rows = Array.isArray(item.json) ? item.json : (Array.isArray(item.json?.items) ? item.json.items : []);\n  const source = rows[0]?.source || rows[0]?.platform || item.json?.source || 'unknown';\n  if (!rows.length) { sourceStatus[source] = {status:'empty_or_error', count:0}; continue; }\n  sourceStatus[source] = {status:'observed', count:Math.min(rows.length,10)};\n  for (const r of rows.slice(0, 10)) {\n    const s = String(r.source || r.platform || source).toLowerCase().includes('google') ? 'google' : String(r.source || r.platform || source).toLowerCase().includes('tiktok') ? 'tiktok' : String(r.source || r.platform || source).toLowerCase().includes('meta') || String(r.source || r.platform || source).toLowerCase().includes('facebook') ? 'meta' : source;\n    const sourceAdId = String(r.source_ad_id || r.adArchiveId || r.adId || r.creativeId || r.id || '').trim();\n    if (!sourceAdId) continue;\n    normalized.push({source:s, coverage_type:'public_library_results', source_ad_id:sourceAdId, advertiser_name:r.advertiser_name||r.pageName||r.advertiserName||r.brandName||'', message_primary:r.message_primary||r.adText||r.text||r.title||'', evidence_url:r.evidence_url||r.url||r.adSnapshotUrl||r.landingPageUrl||'', observed_at:new Date().toISOString(), source_signals:r.source_signals||{rawFields:Object.keys(r).slice(0,20)}, snapshot_state:'new'});\n  }\n}\nconst seen = new Set();\nconst capped = normalized.filter(r => { const k = `${r.source}:${r.source_ad_id}`; if (seen.has(k)) return false; seen.add(k); return true; }).slice(0,30);\nreturn [{json:{normalized:capped,counts:{total:capped.length,bySource:sourceStatus},warnings:Object.entries(sourceStatus).filter(([,v])=>v.status!=='observed').map(([s])=>`${s}: no observed rows; rendered as absence, not retirement`)}}];"
      },
      "id": "23100000-0000-4000-8000-000000000011",
      "name": "Normalize Rows and Compare Snapshot",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
