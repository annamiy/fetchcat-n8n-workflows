    {
      "parameters": {
        "jsCode": "const items = [...$('Annotate Meta Rows with Provenance').all(), ...$('Annotate Google Rows with Provenance').all(), ...$('Annotate Tiktok Rows with Provenance').all()];\nconst normalized = [];\nconst sourceStatus = {};\nlet ctx = {};\nfor (const item of items) {\n  const source = item.json.source || 'unknown';\n  const rows = Array.isArray(item.json.rows) ? item.json.rows : [];\n  ctx = {...ctx, runKey:item.json.runKey, idempotencyKey:item.json.idempotencyKey, watchlistLabel:item.json.watchlistLabel, market:item.json.market, slackNotify:item.json.slackNotify};\n  if (!rows.length) { sourceStatus[source] = {status:item.json.status || 'empty_or_error', count:0, apifyRunId:item.json.apifyRunId, apifyDatasetId:item.json.apifyDatasetId}; continue; }\n  sourceStatus[source] = {status:'observed', count:Math.min(rows.length,10), apifyRunId:item.json.apifyRunId, apifyDatasetId:item.json.apifyDatasetId};\n  for (const r of rows.slice(0, 10)) {\n    const sourceAdId = String(r.source_ad_id || r.adArchiveId || r.adId || r.creativeId || r.id || '').trim();\n    if (!sourceAdId) continue;\n    normalized.push({source, coverage_type:'public_library_results', source_ad_id:sourceAdId, advertiser_name:r.advertiser_name||r.pageName||r.advertiserName||r.brandName||'', message_primary:r.message_primary||r.adText||r.text||r.title||'', evidence_url:r.evidence_url||r.url||r.adSnapshotUrl||r.landingPageUrl||'', observed_at:new Date().toISOString(), apify_run_id:r.apifyRunId, apify_dataset_id:r.apifyDatasetId, source_signals:r.source_signals||{rawFields:Object.keys(r).slice(0,20)}, snapshot_state:'new'});\n  }\n}\nconst seen = new Set();\nconst capped = normalized.filter(r => { const k = `${r.source}:${r.source_ad_id}`; if (seen.has(k)) return false; seen.add(k); return true; }).slice(0,30);\nreturn [{json:{...ctx, normalized:capped,counts:{total:capped.length,bySource:sourceStatus},warnings:Object.entries(sourceStatus).filter(([,v])=>v.status!=='observed').map(([s])=>`${s}: no observed rows; rendered as absence, not retirement`)}}];"
      },
      "id": "23100000-0000-4000-8000-000000000011",
      "name": "Normalize Rows and Compare Snapshot",
      "type": "n8n-nodes-base.code",
