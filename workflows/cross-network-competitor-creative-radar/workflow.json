    {
      "parameters": {
        "jsCode": "const watchlistLabel = String($json.watchlistLabel || '').trim();\nconst market = String($json.market || '').trim() || 'US';\nconst requested = Number($json.itemsPerSource ?? 10);\nconst itemsPerSource = Math.max(1, Math.min(Number.isFinite(requested) ? requested : 10, 10));\nif (!watchlistLabel) throw new Error('watchlistLabel is required before any Apify, AI, Drive, or Slack spend.');\nconst sources = ['meta','google','tiktok'];\nconst runKey = `${watchlistLabel.toLowerCase().replace(/[^a-z0-9]+/g,'-')}:${market}:${new Date().toISOString().slice(0,10)}`;\nreturn [{json:{watchlistLabel,market,itemsPerSource,slackNotify:Boolean($json.slackNotify),runKey,caps:{itemsPerSource:10,actorRuns:3,totalRows:30,aiRequests:1,driveWrites:1,slackWrites:1},actorInputs:{meta:{query:watchlistLabel,country:market,maxItems:itemsPerSource},google:{query:watchlistLabel,region:market,maxResultsPerQuery:itemsPerSource},tiktok:{query:watchlistLabel,country:market,maxItems:itemsPerSource}},sourceOrder:sources}}];"
      },
      "id": "23100000-0000-4000-8000-000000000007",
      "name": "Validate Setup and Build Actor Inputs",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -860,
        20
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.apify.com/v2/acts/fetch_cat~facebook-ads-library-scraper/runs?waitForFinish=120&token={{$env.APIFY_TOKEN}}",
        "sendBody": true,
        "jsonBody": "={$json.actorInputs.meta}",
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      },
