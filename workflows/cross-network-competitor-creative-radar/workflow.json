    {
      "parameters": {
        "jsCode": "const setup = $('Validate Setup and Build Actor Inputs').first().json;\nconst run = $('Run Meta Actor (fetch_cat/facebook-ads-library-scraper)').first()?.json || {};\nconst datasetId = run.data?.defaultDatasetId || run.defaultDatasetId || '';\nconst runId = run.data?.id || run.id || '';\nconst rows = $input.all().flatMap(i => Array.isArray(i.json) ? i.json : (Array.isArray(i.json?.items) ? i.json.items : []));\nreturn [{json:{source:'meta', rows: rows.slice(0, setup.itemsPerSource || 10).map(r => ({...r, source:'meta', apifyRunId: runId, apifyDatasetId: datasetId})), status: rows.length ? 'observed' : 'empty_or_error', apifyRunId: runId, apifyDatasetId: datasetId, runKey: setup.runKey, idempotencyKey: setup.idempotencyKey, watchlistLabel: setup.watchlistLabel, market: setup.market, slackNotify: setup.slackNotify}}];"
